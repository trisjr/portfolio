---
import "../styles/space.css";

interface Props {
  title: string;
  active?: "home" | "projects" | "blog" | "about" | "contact";
}

const {title, active = "home"} = Astro.props;
const isActive = (key: Props["active"]) => (active === key ? "active" : "");
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
            rel="stylesheet"
    />
    <slot name="head"/>
</head>
<body>
<canvas id="space-canvas"></canvas>
<div class="bg-aura"></div>
<div class="bg-grid"></div>
<div class="scanlines"></div>

<nav class="nav">
    <div class="nav__in">
        <a class="brand" href="/"><span class="brand__mark">T<b>/</b></span>Tris<b>Jr</b></a>
        <div class="nav__links">
            <a href="/" class={isActive("home")}>Home</a>
            <a href="/projects" class={isActive("projects")}>Projects</a>
            <a href="/blog" class={isActive("blog")}>Blog</a>
            <a href="/about" class={isActive("about")}>About</a>
        </div>
        <a class="btn btn--primary nav__cta" href="/contact">Let's talk</a>
        <button class="nav__burger" aria-label="Open menu"><span></span><span></span><span></span></button>
    </div>
</nav>

<div class="drawer">
    <div class="drawer__scrim"></div>
    <aside class="drawer__panel">
        <button class="drawer__close" aria-label="Close menu">&times;</button>
        <a href="/" class={isActive("home")}>Home</a>
        <a href="/projects" class={isActive("projects")}>Projects</a>
        <a href="/blog" class={isActive("blog")}>Blog</a>
        <a href="/about" class={isActive("about")}>About</a>
        <a href="/contact" class={isActive("contact")}>Contact</a>
    </aside>
</div>

<slot/>

<footer class="footer">
    <div class="wrap">
        <div class="footer__grid">
            <div>
                <a class="brand" href="/"><span class="brand__mark">T<b>/</b></span>Tris<b>Jr</b></a>
                <p style="color:var(--dim);max-width:34ch;margin:var(--md) 0 0;font-size:14.5px">Full-stack developer
                    &amp; digital architect, building fast, thoughtful software from the metaverse of my terminal.</p>
                <div class="socials" style="margin-top:var(--lg)">
                    <a href="#" aria-label="GitHub">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.34 1.12 2.91.85.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9v2.82c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="LinkedIn">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0zM.25 8.25h4.5V24H.25zM8.25 8.25h4.31v2.15h.06c.6-1.13 2.07-2.32 4.26-2.32 4.56 0 5.4 3 5.4 6.9V24h-4.5v-6.96c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.67 1.8-2.67 3.67V24h-4.5z"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="X">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18.9 2H22l-7.6 8.7L23.3 22h-6.9l-5.4-7-6.2 7H1.7l8.2-9.3L1 2h7.1l4.9 6.4L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/>
                        </svg>
                    </a>
                </div>
            </div>
            <div><h4>Navigate</h4>
                <div class="footer__links"><a href="/">Home</a><a href="/projects">Projects</a><a
                        href="/blog">Blog</a><a href="/about">About</a><a href="/contact">Contact</a></div>
            </div>
            <div><h4>Elsewhere</h4>
                <div class="footer__links"><a href="#">GitHub</a><a href="#">LinkedIn</a><a href="#">Dribbble</a><a
                        href="#">Read.cv</a></div>
            </div>
        </div>
        <div class="footer__bottom">
            <span><span class="spin">✦</span> &nbsp;© <span data-year>2026</span> TrisJr. Crafted in the void.</span>
            <span>Built with caffeine &amp; curiosity</span>
        </div>
    </div>
</footer>

<button id="totop" aria-label="Back to top">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 19V5M6 11l6-6 6 6"/>
    </svg>
</button>
<button id="tw-open" aria-label="Open tweaks panel">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
</button>

<div id="tweaks">
    <div class="tw__head"><h5>Tweaks</h5>
        <button class="tw__x" aria-label="Close">&times;</button>
    </div>
    <div class="tw__body">
        <div class="tw__row"><label>Accent palette</label>
            <div class="tw__swatches">
                <div class="tw__sw" data-acc="blue"></div>
                <div class="tw__sw" data-acc="cyan"></div>
                <div class="tw__sw" data-acc="purple"></div>
                <div class="tw__sw" data-acc="pink"></div>
            </div>
        </div>
        <div class="tw__row"><label>Particle density</label>
            <div class="tw__seg">
                <button data-dens="calm">Calm</button>
                <button data-dens="regular">Regular</button>
                <button data-dens="dense">Dense</button>
            </div>
        </div>
        <div class="tw__row"><label>Glow strength</label><input class="tw__range" type="range" min="0" max="1.6"
                                                                step="0.1" data-glow></div>
        <div class="tw__row tw__toggle"><label>Grid background</label>
            <div class="tw__switch" data-grid></div>
        </div>
        <div class="tw__row tw__toggle"><label>Scanline overlay</label>
            <div class="tw__switch" data-scan></div>
        </div>
    </div>
</div>

<slot name="data"/>
<script is:inline src="/assets/space.js"></script>
<slot name="scripts"/>
</body>
</html>
