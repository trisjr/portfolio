---
import { getEntry } from "astro:content";
import { ClientRouter } from "astro:transitions";
import Icon from "../components/Icon.astro";
import { url } from "../lib/path";
import "../styles/space.css";

interface Props {
  title: string;
  active?: "home" | "projects" | "blog" | "about" | "contact";
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "profile";
}

const profile = await getEntry("profile", "me");
const p = profile!.data;

const {
  title,
  active = "home",
  description = p.heroBio,
  ogImage = "/og.png",
  ogType = "website",
} = Astro.props;
const isActive = (key: Props["active"]) => (active === key ? "active" : "");

// Absolute URLs for SEO/social — OG requires absolute. Astro.url.pathname
// already includes the base path, so it isn't passed through url(); a /public
// asset like ogImage does need url() to gain the base prefix. Astro.site is
// the bare origin.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(url(ogImage), Astro.site);

// JSON-LD Person schema — site-wide identity for rich results.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: p.name,
  url: new URL(url("/"), Astro.site).href,
  image: new URL(url(p.avatar), Astro.site).href,
  jobTitle: p.role,
  description: p.heroBio,
  sameAs: p.socials.map((s: { url: string }) => s.url),
};
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")}/>
    <link rel="alternate icon" type="image/x-icon" href={url("/favicon.ico")}/>
    <title>{title}</title>
    <meta name="description" content={description}/>
    <meta name="author" content={p.name}/>
    <link rel="canonical" href={canonical}/>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType}/>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonical}/>
    <meta property="og:image" content={ogImageUrl}/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="630"/>
    <meta property="og:site_name" content={p.name}/>
    <meta property="og:locale" content="en_US"/>

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content={title}/>
    <meta name="twitter:description" content={description}/>
    <meta name="twitter:image" content={ogImageUrl}/>
    <meta name="twitter:creator" content="@trisjr"/>

    <link rel="alternate" type="application/rss+xml" title={`${p.name} — Blog`} href={url("/rss.xml")}/>
    <script type="application/ld+json" set:html={JSON.stringify(personLd)}/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
            rel="stylesheet"
    />
    <ClientRouter />
    <slot name="head"/>
</head>
<body>
<canvas id="space-canvas" transition:persist></canvas>
<div class="bg-aura" transition:persist></div>
<div class="bg-grid" transition:persist></div>
<div class="scanlines" transition:persist></div>
<div class="cursor-dot" transition:persist="cursor-dot"></div>
<div class="cursor-ring" transition:persist="cursor-ring"></div>

<nav class="nav">
    <div class="nav__in">
        <a class="brand" href={url("/")}><span class="brand__mark">{p.initial}<b>_</b></span>{p.brand.first}<b>{p.brand.last}</b></a>
        <div class="nav__links">
            <a href={url("/")} class={isActive("home")}>Home</a>
            <a href={url("/projects")} class={isActive("projects")}>Projects</a>
            <a href={url("/blog")} class={isActive("blog")}>Blog</a>
            <a href={url("/about")} class={isActive("about")}>About</a>
        </div>
        <a class="btn btn--primary nav__cta" href={url("/contact")}>Let's talk</a>
        <button class="nav__burger" aria-label="Open menu"><span></span><span></span><span></span></button>
    </div>
</nav>

<div class="drawer">
    <div class="drawer__scrim"></div>
    <aside class="drawer__panel">
        <button class="drawer__close" aria-label="Close menu">&times;</button>
        <a href={url("/")} class={isActive("home")}>Home</a>
        <a href={url("/projects")} class={isActive("projects")}>Projects</a>
        <a href={url("/blog")} class={isActive("blog")}>Blog</a>
        <a href={url("/about")} class={isActive("about")}>About</a>
        <a href={url("/contact")} class={isActive("contact")}>Contact</a>
    </aside>
</div>

<slot/>

<footer class="footer">
    <div class="wrap">
        <div class="footer__grid">
            <div>
                <a class="brand" href={url("/")}><span class="brand__mark">{p.initial}<b>_</b></span>{p.brand.first}<b>{p.brand.last}</b></a>
                <p style="color:var(--dim);max-width:34ch;margin:var(--md) 0 0;font-size:14.5px">{p.footerTagline}</p>
                <div class="socials" style="margin-top:var(--lg)">
                    {p.socials.map((s: { url: string | URL | null | undefined; name: string | null | undefined; icon: string; }) => (
                        <a href={s.url} aria-label={s.name}><Icon name={s.icon} /></a>
                    ))}
                </div>
            </div>
            <div><h4>Navigate</h4>
                <div class="footer__links"><a href={url("/")}>Home</a><a href={url("/projects")}>Projects</a><a
                        href={url("/blog")}>Blog</a><a href={url("/about")}>About</a><a href={url("/contact")}>Contact</a><a href={url("/resume")}>Résumé</a></div>
            </div>
            <div><h4>Elsewhere</h4>
                <div class="footer__links">{p.elsewhere.map((e: { url: string | URL | null | undefined; name: unknown; }) => <a href={e.url}>{e.name}</a>)}<a href={url("/rss.xml")}>RSS</a></div>
            </div>
        </div>
        <div class="footer__bottom">
            <span><span class="spin">✦</span> &nbsp;© <span data-year>2026</span> {p.name}. Crafted in the void.</span>
            <span>Built with caffeine &amp; curiosity</span>
        </div>
    </div>
</footer>

<button id="totop" aria-label="Back to top">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 19V5M6 11l6-6 6 6"/>
    </svg>
</button>
<button id="tw-open" aria-label="Open tweaks panel">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
</button>

<div id="tweaks">
    <div class="tw__head"><h5>Tweaks</h5>
        <button class="tw__x" aria-label="Close">&times;</button>
    </div>
    <div class="tw__body">
        <div class="tw__row"><label>Accent palette</label>
            <div class="tw__swatches">
                <div class="tw__sw" data-acc="blue"></div>
                <div class="tw__sw" data-acc="cyan"></div>
                <div class="tw__sw" data-acc="purple"></div>
                <div class="tw__sw" data-acc="pink"></div>
            </div>
        </div>
        <div class="tw__row"><label>Particle density</label>
            <div class="tw__seg">
                <button data-dens="calm">Calm</button>
                <button data-dens="regular">Regular</button>
                <button data-dens="dense">Dense</button>
            </div>
        </div>
        <div class="tw__row"><label>Glow strength</label><input class="tw__range" type="range" min="0" max="1.6"
                                                                step="0.1" data-glow></div>
        <div class="tw__row tw__toggle"><label>Grid background</label>
            <div class="tw__switch" data-grid></div>
        </div>
        <div class="tw__row tw__toggle"><label>Scanline overlay</label>
            <div class="tw__switch" data-scan></div>
        </div>
    </div>
</div>

<script is:inline src={url("/assets/space.js")}></script>
<slot name="scripts"/>
</body>
</html>
