---
import Layout from "../layouts/Layout.astro";
import "../styles/pages/projects.css";
---

<Layout title="Projects — TrisJr" active="projects">
    <main>
        <section class="wrap page-head" data-screen-label="Projects header">
            <p class="kicker reveal">// the work</p>
            <h1 class="h-glow reveal" data-d="1">Projects from <span class="gradient-text">the void</span></h1>
            <p class="reveal" data-d="2">Systems, tools, and experiments I've designed and shipped. Click any node to
                open its dossier.</p>
            <div class="filters reveal" data-d="3" id="filters"></div>
        </section>

        <section class="wrap" style="padding-bottom:var(--4xl)">
            <div class="grid" id="grid"></div>
        </section>
    </main>

    <!-- modal -->
    <div class="modal" id="modal" role="dialog" aria-modal="true">
        <div class="modal__scrim" data-close></div>
        <div class="card modal__panel" id="modalPanel">
            <button class="modal__close" data-close aria-label="Close">&times;</button>
            <div id="modalContent"></div>
        </div>
    </div>

    <script is:inline src="/assets/projects-data.js" slot="data"></script>
    <script is:inline slot="scripts">
      (function () {
        const grid = document.getElementById("grid");
        const filtersEl = document.getElementById("filters");
        const cats = ["All", ...Array.from(new Set(PROJECTS.map(p => p.category.split(" · ")[0])))];
        let active = "All";

        cats.forEach((c, i) => {
          const b = document.createElement("button");
          b.className = "filter" + (i === 0 ? " on" : "");
          b.textContent = c;
          b.dataset.cat = c;
          b.addEventListener("click", () => {
            active = c;
            filtersEl.querySelectorAll(".filter").forEach(f => f.classList.toggle("on", f === b));
            render();
          });
          filtersEl.appendChild(b);
        });

        function viz(p) {
          return `<div class="proj__viz" style="background:radial-gradient(70% 90% at 50% 30%,rgba(${p.tint},.14),transparent)">
        <span class="ring" style="border-color:rgba(${p.tint},.5)"></span>
        <span class="ring" style="border-color:rgba(${p.tint},.7)"></span>
        <span class="core" style="background:rgb(${p.tint});box-shadow:0 0 18px rgb(${p.tint})"></span>
      </div>`;
        }

        function render() {
          grid.innerHTML = "";
          PROJECTS.filter(p => active === "All" || p.category.startsWith(active)).forEach((p, i) => {
            const card = document.createElement("article");
            card.className = "card proj reveal";
            card.dataset.d = (i % 4) + 1;
            card.dataset.id = p.id;
            card.innerHTML = `
          <div class="proj__top"><span class="proj__num">P / 0${i + 1}</span><span class="proj__yr">${p.year}</span></div>
          ${viz(p)}
          <div class="proj__body">
            <span class="proj__cat" style="color:rgb(${p.tint})">${p.category}</span>
            <h3>${p.title}</h3>
            <p>${p.tagline}</p>
            <div class="chips">${p.stack.slice(0, 4).map(s => `<span class="chip">${s}</span>`).join("")}</div>
          </div>`;
            card.addEventListener("click", () => openModal(p.id));
            grid.appendChild(card);
          });
          grid.querySelectorAll(".reveal").forEach(el => el.classList.add("in"));
        }

        // modal
        const modal = document.getElementById("modal");
        const mc = document.getElementById("modalContent");

        function openModal(id) {
          const p = PROJECTS.find(x => x.id === id);
          if (!p) return;
          mc.innerHTML = `
        <div class="modal__hero" style="background:radial-gradient(80% 120% at 50% 0%,rgba(${p.tint},.22),transparent)">
          <span class="modal__num" style="color:rgba(${p.tint},.6)">${p.title[0]}</span>
        </div>
        <div class="modal__in">
          <span class="proj__cat" style="color:rgb(${p.tint})">${p.category}</span>
          <h2>${p.title}</h2>
          <div class="modal__meta">
            <div><span>Year</span><b>${p.year}</b></div>
            <div><span>Role</span><b>${p.role}</b></div>
            <div><span>Stack</span><b>${p.stack.length} tech</b></div>
          </div>
          <p>${p.desc}</p>
          <ul class="modal__hl">${p.highlights.map(h => `<li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>${h}</li>`).join("")}</ul>
          <div class="chips">${p.stack.map(s => `<span class="chip chip--on">${s}</span>`).join("")}</div>
          <div class="modal__actions">
            <a class="btn btn--primary" href="${p.links.live}" target="_blank" rel="noopener">View live<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg></a>
            <a class="btn btn--ghost" href="${p.links.code}" target="_blank" rel="noopener">Source code</a>
          </div>
        </div>`;
          modal.classList.add("open");
          document.body.style.overflow = "hidden";
          history.replaceState(null, "", "#" + id);
        }

        function closeModal() {
          modal.classList.remove("open");
          document.body.style.overflow = "";
          history.replaceState(null, "", location.pathname);
        }

        modal.querySelectorAll("[data-close]").forEach(el => el.addEventListener("click", closeModal));
        document.addEventListener("keydown", e => {
          if (e.key === "Escape") closeModal();
        });

        render();
        // deep link
        if (location.hash) {
          const id = location.hash.slice(1);
          if (PROJECTS.find(p => p.id === id)) openModal(id);
        }
      })();
    </script>
</Layout>
