---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/path";
import "../styles/pages/home.css";

const me = (await getEntry("profile", "me"))!.data;

const featTints = [
    "rgba(0,217,255,.10)",
    "rgba(187,134,252,.10)",
    "rgba(255,0,110,.08)",
];
const featured = (await getCollection("projects"))
    .filter((p) => p.data.featured)
    .sort((a, b) => a.data.order - b.data.order)
    .slice(0, 3);
---

<Layout title="TrisJr — Full-Stack Developer" active="home">
    <main>
        <!-- HERO -->
        <header class="hero wrap" data-screen-label="Hero">
            <div class="hero__grid">
                <div>
                    <p class="kicker reveal">{me.titles.join(" · ")}</p>
                    <h1 class="hero__title reveal" data-d="1">
                        Building digital<br>worlds through
                        <span class="hero__roles"><span id="role" class="gradient-text" data-words={JSON.stringify(me.roles)}>{me.roles[0]}</span></span>
                    </h1>
                    <p class="hero__sub reveal" data-d="2">{me.heroBio}</p>
                    <div class="hero__cta reveal" data-d="3">
                        <a class="btn btn--primary" href={url("/projects")}>
                            Explore my work
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M13 6l6 6-6 6"/>
                            </svg>
                        </a>
                        <a class="btn btn--ghost" href={url("/contact")}>Start a collaboration</a>
                    </div>
                    <div class="hero__stats reveal" data-d="4">
                        {me.stats.map((s) => (
                            <div class="stat"><b><span data-count={s.value} data-suffix={s.suffix}>0</span></b><span>{s.label}</span></div>
                        ))}
                    </div>
                </div>
                <div class="hero__media reveal" data-d="2">
                    <div class="card term">
                        <div class="term__bar">
                            <span class="term__dot" style="background:#FF5F56"></span>
                            <span class="term__dot" style="background:#FFBD2E"></span>
                            <span class="term__dot" style="background:#27C93F"></span>
                            <span class="term__title">~/trisjr/profile.ts</span>
                        </div>
                        <div class="term__body">
                            <div class="ln"><span class="k">const</span> <span class="f">trisjr</span> = &#123;</div>
                            <div class="ln"> role: <span class="s">"{me.terminal.role}"</span>,</div>
                            <div class="ln"> stack: [{me.terminal.stack.map((t, i) => (
                                <Fragment>{i > 0 ? ", " : ""}<span class="s">"{t}"</span></Fragment>
                            ))}],</div>
                            <div class="ln"> focus: <span class="s">"{me.terminal.focus}"</span>,</div>
                            <div class="ln"> coffee: <span class="n">Infinity</span>,</div>
                            <div class="ln"><span class="f">ship</span>: () => <span class="s">"🚀"</span>,</div>
                            <div class="ln">&#125;;</div>
                            <div class="ln"><span class="c">// {me.terminal.status}</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="scroll-ind"><span class="mouse"></span>SCROLL</div>
        </header>

        <!-- ABOUT PREVIEW -->
        <section class="section wrap" data-screen-label="About preview">
            <div class="about">
                <div class="reveal">
                    <div class="avatar">
                        <div class="avatar__ring"></div>
                        <div class="avatar__img"><img src={url(me.avatar)} alt={me.name} class="avatar__photo" /></div>
                    </div>
                </div>
                <div>
                    <p class="kicker reveal">// whoami</p>
                    <h2 class="section-title h-glow reveal" data-d="1">{me.aboutPreviewTitle}</h2>
                    <p class="section-sub reveal" data-d="2">{me.aboutPreviewBio}</p>
                    <div class="about__tags reveal" data-d="3">
                        {me.skillChips.map((c) => (
                            <span class={c.primary ? "chip chip--on" : "chip"}>{c.name}</span>
                        ))}
                    </div>
                    <div style="margin-top:var(--xl)" class="reveal" data-d="4">
                        <a class="arrow-link" href={url("/about")}>More about me
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2">
                                <path d="M5 12h14M13 6l6 6-6 6"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- FEATURED -->
        <section class="section wrap" data-screen-label="Featured projects">
            <div class="feat-head">
                <div>
                    <p class="kicker reveal">Selected work</p>
                    <h2 class="section-title h-glow reveal" data-d="1">Featured projects</h2>
                </div>
                <a class="arrow-link reveal" data-d="2" href={url("/projects")}>View all projects
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M13 6l6 6-6 6"/>
                    </svg>
                </a>
            </div>
            <div class="pgrid" id="feat">
                {featured.map((p, i) => (
                    <a class="card pcard reveal" data-d={i + 1} href={url(`/projects#${p.id}`)}>
                        <div class="pcard__thumb" style={`background:linear-gradient(140deg,${featTints[i % 3]},transparent)`}>
                            <div class="pcard__glow" style={`background:radial-gradient(60% 80% at 70% 20%,${featTints[i % 3]},transparent)`}></div>
                            <span class="pcard__num">0{i + 1}</span>
                        </div>
                        <div class="pcard__body">
                            <span class="pcard__cat">{p.data.category}</span>
                            <h3>{p.data.title}</h3>
                            <p>{p.data.tagline}</p>
                            <div class="chips">
                                {p.data.stack.slice(0, 3).map((s) => <span class="chip">{s}</span>)}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <!-- SKILLS PREVIEW -->
        <section class="section section--tight wrap" data-screen-label="Skills">
            <p class="kicker reveal">Capabilities</p>
            <h2 class="section-title h-glow reveal" data-d="1" style="margin-bottom:var(--2xl)">The stack I build
                with</h2>
            <div class="skbar">
                {me.skillGroups.map((g, i) => (
                    <div class="skcat reveal" data-d={i + 1}><h4>{g.title}</h4>
                        <ul>
                            {g.items.map((item) => <li>{item}</li>)}
                        </ul>
                    </div>
                ))}
            </div>
        </section>

        <!-- CTA -->
        <section class="section wrap" data-screen-label="CTA">
            <div class="cta reveal">
                <p class="kicker" style="justify-content:center">Open to new missions</p>
                <h2 class="gradient-text">Ready to collaborate?</h2>
                <p>Whether it's a greenfield product, a gnarly performance problem, or a system that needs rethinking —
                    let's build something worth remembering.</p>
                <a class="btn btn--primary" href={url("/contact")}>
                    Start a conversation
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M13 6l6 6-6 6"/>
                    </svg>
                </a>
            </div>
        </section>
    </main>

    <script slot="scripts">
      // role rotator
      document.addEventListener("astro:page-load", () => {
        const el = document.getElementById("role");
        if (!el) return;
        const words = JSON.parse(el.dataset.words || "[]");
        if (!words.length) return;
        const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) return;
        let wi = 0, ci = 0, del = false, alive = true;
        document.addEventListener("astro:before-swap", () => { alive = false; }, { once: true });

        function tick() {
          if (!alive || !el.isConnected) return; // stop recursive loop on navigation
          const w = words[wi];
          el.textContent = del ? w.slice(0, --ci) : w.slice(0, ++ci);
          let wait = del ? 55 : 95;
          if (!del && ci === w.length) {
            wait = 1700;
            del = true;
          } else if (del && ci === 0) {
            del = false;
            wi = (wi + 1) % words.length;
            wait = 350;
          }
          setTimeout(tick, wait);
        }

        setTimeout(tick, 1400);
      });
    </script>
</Layout>
