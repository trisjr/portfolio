---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/path";
import "../styles/pages/about.css";

const me = (await getEntry("profile", "me"))!.data;

const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const fmtMonth = (d: string) => {
    const [y, m] = d.split("-");
    return `${MONTHS[Number(m) - 1]} ${y}`;
};
const period = (p: { startDate: string; endDate?: string; current: boolean }) => {
    const start = fmtMonth(p.startDate);
    if (p.current) return `${start} — Now`;
    if (p.endDate) return `${start} — ${fmtMonth(p.endDate)}`;
    return start;
};

const timeline = (await getCollection("projects"))
    .sort((a, b) => a.data.order - b.data.order)
    .map((p) => ({
        yr: period(p.data),
        role: p.data.role,
        org: p.data.title,
        desc: p.data.tagline,
    }));
---

<Layout title="About — TrisJr" active="about">
    <main>
        <section class="wrap page-head" data-screen-label="About intro">
            <div class="intro">
                <div class="reveal">
                    <div class="portrait"><img src={url(me.avatar)} alt={me.name} class="portrait__photo" /><span class="dot"></span></div>
                </div>
                <div>
                    <p class="kicker reveal">// whoami --verbose</p>
                    <h1 class="h-glow reveal" data-d="1">I'm {me.name}.<br>I build the <span class="gradient-text">unseen machinery</span>.
                    </h1>
                    {me.aboutBio.map((para, i) => (
                        <p class="reveal" data-d={i + 2}>{para}</p>
                    ))}
                    <div class="hero__cta reveal" data-d="4" style="display:flex;gap:14px;margin-top:var(--lg)">
                        <a class="btn btn--primary" href={url("/contact")}>Work with me</a>
                        <a class="btn btn--ghost" href="#" download>Download CV</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- CONSTELLATION -->
        <section class="section wrap" data-screen-label="Skill constellation">
            <p class="kicker reveal">Skill constellation</p>
            <h2 class="section-title h-glow reveal" data-d="1">A connected map of what I do</h2>
            <p class="section-sub reveal" data-d="2" style="margin-bottom:var(--2xl)">Hover any node to light up the
                network. Bigger orbs are deeper specialties.</p>
            <div class="card const-wrap reveal" data-d="2" style="padding:var(--lg)">
                <div class="const" id="const" data-nodes={JSON.stringify(me.constellation.nodes)} data-links={JSON.stringify(me.constellation.links)}>
                    <svg id="constLines"></svg>
                </div>
            </div>
        </section>

        <!-- TIMELINE -->
        <section class="section wrap" data-screen-label="Experience timeline">
            <p class="kicker reveal">Trajectory</p>
            <h2 class="section-title h-glow reveal" data-d="1" style="margin-bottom:var(--xl)">Experience log</h2>
            <div class="timeline" id="timeline" data-jobs={JSON.stringify(timeline)}></div>
        </section>

        <!-- VALUES -->
        <section class="section section--tight wrap" data-screen-label="Values">
            <p class="kicker reveal">Operating principles</p>
            <h2 class="section-title h-glow reveal" data-d="1" style="margin-bottom:var(--2xl)">How I work</h2>
            <div class="values">
                <div class="card value reveal" data-d="1">
                    <div class="ico">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="m13 2-3 7h5l-3 7"/>
                            <circle cx="12" cy="12" r="9"/>
                        </svg>
                    </div>
                    <h4>{me.values[0].title}</h4>
                    <p>{me.values[0].desc}</p>
                </div>
                <div class="card value reveal" data-d="2">
                    <div class="ico">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="3"/>
                            <path d="M9 9h6v6H9z"/>
                        </svg>
                    </div>
                    <h4>{me.values[1].title}</h4>
                    <p>{me.values[1].desc}</p>
                </div>
                <div class="card value reveal" data-d="3">
                    <div class="ico">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2">
                            <path d="M12 2a10 10 0 1 0 10 10"/>
                            <path d="M12 8v4l3 2"/>
                        </svg>
                    </div>
                    <h4>{me.values[2].title}</h4>
                    <p>{me.values[2].desc}</p>
                </div>
            </div>
        </section>
    </main>

    <script is:inline slot="scripts">
      (function () {
        // ---- skill constellation ----
        const cont = document.getElementById("const");
        const svg = document.getElementById("constLines");
        const skills = JSON.parse(cont.dataset.nodes || "[]");
        const links = JSON.parse(cont.dataset.links || "[]");
        skills.forEach((sk, i) => {
          const n = document.createElement("div");
          n.className = "node node--" + sk.s;
          n.dataset.i = i;
          n.style.left = sk.x + "%";
          n.style.top = sk.y + "%";
          n.innerHTML = `<div class="node__orb">${sk.l.length > 5 ? sk.l.slice(0, 2).toUpperCase() : sk.l}</div><span class="node__label">${sk.l}</span>`;
          cont.appendChild(n);
        });

        function drawLines() {
          const rect = cont.getBoundingClientRect();
          svg.setAttribute("viewBox", `0 0 ${rect.width} ${rect.height}`);
          const pos = skills.map(s => ({x: s.x / 100 * rect.width, y: s.y / 100 * rect.height}));
          svg.innerHTML = links.map(([a, b], i) => `<line data-a="${a}" data-b="${b}" x1="${pos[a].x}" y1="${pos[a].y}" x2="${pos[b].x}" y2="${pos[b].y}"
          stroke="rgba(var(--accent-rgb),.18)" stroke-width="1"/>`).join("");
        }

        drawLines();
        window.addEventListener("resize", drawLines);
        cont.querySelectorAll(".node").forEach(n => {
          n.addEventListener("mouseenter", () => {
            const i = +n.dataset.i;
            svg.querySelectorAll("line").forEach(ln => {
              const on = +ln.dataset.a === i || +ln.dataset.b === i;
              ln.setAttribute("stroke", on ? "rgba(var(--accent-rgb),.8)" : "rgba(var(--accent-rgb),.08)");
              ln.setAttribute("stroke-width", on ? "2" : "1");
            });
          });
          n.addEventListener("mouseleave", () => {
            svg.querySelectorAll("line").forEach(ln => {
              ln.setAttribute("stroke", "rgba(var(--accent-rgb),.18)");
              ln.setAttribute("stroke-width", "1");
            });
          });
        });

        // ---- timeline ----
        const tl = document.getElementById("timeline");
        const jobs = JSON.parse(tl.dataset.jobs || "[]");
        jobs.forEach((j, i) => {
          const el = document.createElement("div");
          el.className = "tl-item reveal";
          el.dataset.d = (i % 4) + 1;
          el.innerHTML = `<span class="yr">${j.yr}</span><h3>${j.role}</h3><div class="org">${j.org}</div><p>${j.desc}</p>`;
          tl.appendChild(el);
        });
        // these nodes were appended after initial reveal pass — reveal them via the shared helper
        if (window.__revealInView) window.__revealInView(tl); else tl.querySelectorAll(".reveal").forEach(el => el.classList.add("in"));
      })();
    </script>
</Layout>
