---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { url } from "../../lib/path";
import "../../styles/pages/lab.css";

const experiments = (await getCollection("lab")).sort(
    (a, b) => a.data.order - b.data.order,
);

const fmtDate = (d: Date) =>
    d.toLocaleDateString("en-US", { month: "long", year: "numeric" });

const statusLabel: Record<string, string> = {
    live: "Live",
    wip: "In progress",
    concept: "Concept",
};
---

<Layout title="Lab — TrisJr" active="lab" description="A sandbox of small, self-contained interactive experiments by TrisJr — simulations, toys and ideas built for the joy of it.">
    <main>
        <section class="wrap page-head" data-screen-label="Lab header">
            <p class="kicker reveal">// the sandbox</p>
            <h1 class="h-glow reveal" data-d="1">Experiments from <span class="gradient-text">the void</span></h1>
            <p class="reveal" data-d="2">Small, self-contained ideas built for the joy of building them — simulations,
                toys, and interactions. Open one and play.</p>
        </section>

        <section class="wrap" style="padding-bottom:var(--4xl)">
            <div class="lab-grid">
                {experiments.map((e, i) => (
                    <a class="card lab-card reveal" data-d={(i % 3) + 1} href={url(`/lab/${e.id}`)}
                       style={`--tint:${e.data.tint}`}>
                        <div class="lab-card__viz" style={`background:radial-gradient(75% 90% at 50% 25%,rgba(${e.data.tint},.18),transparent)`}>
                            <span class="lab-card__sun" style={`background:rgb(${e.data.tint});box-shadow:0 0 26px rgb(${e.data.tint})`}></span>
                            <span class="lab-card__ring"></span>
                            <span class="lab-card__ring lab-card__ring--2"></span>
                            <span class={`lab-card__status lab-card__status--${e.data.status}`}>{statusLabel[e.data.status] ?? e.data.status}</span>
                        </div>
                        <div class="lab-card__body">
                            <div class="lab-card__top">
                                <span class="lab-card__cat" style={`color:rgb(${e.data.tint})`}>{e.data.cat}</span>
                                <span class="lab-card__date">{fmtDate(e.data.pubDate)}</span>
                            </div>
                            <h3>{e.data.title}</h3>
                            <p>{e.data.excerpt}</p>
                            <div class="chips">
                                {e.data.stack.slice(0, 3).map((s) => <span class="chip">{s}</span>)}
                            </div>
                            <span class="lab-card__cta">Open experiment →</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <script slot="scripts">
      document.addEventListener("astro:page-load", () => {
        if (window.__revealInView) window.__revealInView();
      });
    </script>
</Layout>
