---
import { getCollection, getEntry } from "astro:content";
import { url } from "../lib/path";

const me = (await getEntry("profile", "me"))!.data;
const cv = me.cv;

const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const fmtMonth = (d: string) => {
  const [y, m] = d.trim().split("-");
  return `${MONTHS[Number(m) - 1]} ${y}`;
};
const period = (p: { startDate: string; endDate?: string; current: boolean }) => {
  const start = fmtMonth(p.startDate);
  if (p.current) return `${start} — Now`;
  if (p.endDate) return `${start} — ${fmtMonth(p.endDate)}`;
  return start;
};

// Professional experience — the curated 11 projects, newest first.
const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

const ogImageUrl = new URL(url("/og.png"), Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
const title = `${me.name} — Résumé`;
// Default filename the browser proposes when saving the print dialog as PDF.
const cvFileName = `${me.name.replace(/\s+/g, "_")}_CV`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
  <title>{title}</title>
  <meta name="description" content={me.aboutPreviewBio} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={me.aboutPreviewBio} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonical} />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body data-cv-name={cvFileName}>
  <button class="print-bar" onclick="window.print()" aria-label="Print or save as PDF">
    ⌘P · Save as PDF
  </button>

  <main class="cv">
    <header class="cv__head">
      <div>
        <h1>{me.name}</h1>
        <p class="cv__role">{me.titles.join(" · ")}</p>
        <p class="cv__bio">{me.aboutPreviewBio}</p>
      </div>
      <ul class="cv__contact">
        {me.contact.channels.map((c) => (
          <li><a href={c.url}>{c.value}</a></li>
        ))}
        <li>{me.contact.status}</li>
      </ul>
    </header>

    {cv && (
      <section class="cv__section">
        <h2>Personal Details</h2>
        <dl class="cv__details">
          <div><dt>Designation</dt><dd>{cv.designation}</dd></div>
          {cv.gender && <div><dt>Gender</dt><dd>{cv.gender}</dd></div>}
          <div><dt>Education</dt><dd>{cv.education.degree} — {cv.education.school}</dd></div>
          {cv.languages.length > 0 && (
            <div><dt>Languages</dt><dd>{cv.languages.map((l) => `${l.name} (${l.level})`).join(" · ")}</dd></div>
          )}
        </dl>
      </section>
    )}

    {cv && (cv.summary.length > 0 || cv.technicalSkills.length > 0) && (
      <section class="cv__section">
        <h2>Professional Summary</h2>
        {cv.summary.map((para) => <p class="cv__desc cv__summary-line">{para}</p>)}
        {cv.technicalSkills.length > 0 && (
          <div class="cv__skills cv__skills--tax">
            {cv.technicalSkills.map((g) => (
              <div class="cv__entry">
                <strong>{g.title}</strong>
                <span>{g.items.join(" · ")}</span>
              </div>
            ))}
          </div>
        )}
        {cv.softSkills.length > 0 && (
          <div class="cv__soft">
            <strong>Soft Skills</strong>
            <ul>
              {cv.softSkills.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        )}
      </section>
    )}

    {cv && cv.proficiency.length > 0 && (
      <section class="cv__section">
        <h2>Technical Expertise &amp; Skills</h2>
        <table class="cv__table">
          <thead>
            <tr><th>Skill</th><th>Proficiency</th><th>Experience</th><th>Last used</th></tr>
          </thead>
          <tbody>
            {cv.proficiency.map((s) => (
              <tr>
                <td><strong>{s.skill}</strong></td>
                <td>
                  <span class="cv__bar" aria-hidden="true">
                    {[1, 2, 3, 4, 5].map((n) => (
                      <span class={n <= s.level ? "on" : ""}></span>
                    ))}
                  </span>
                  <span class="cv__level">{s.level}/5</span>
                </td>
                <td>{s.experience}</td>
                <td>{s.lastUsed}</td>
              </tr>
            ))}
          </tbody>
        </table>
        {cv.proficiencyLegend.length > 0 && (
          <p class="cv__legend">{cv.proficiencyLegend.join("   ·   ")}</p>
        )}
      </section>
    )}

    <section class="cv__section">
      <h2>Professional Experience</h2>
      {projects.map((p) => {
        const d = p.data;
        return (
          <article class="cv__proj">
            <div class="cv__proj-head">
              <strong>{d.title}</strong>
              <span class="cv__yr">{period(d)}</span>
            </div>
            <p class="cv__proj-meta">
              {d.category}
              <span> · {d.role}</span>
              {d.teamSize && <span> · Team of {d.teamSize}</span>}
            </p>
            <p class="cv__desc">{d.tagline}</p>
            {d.responsibilities.length > 0 ? (
              <div class="cv__resp">
                {d.responsibilities.map((r) => (
                  <div class="cv__resp-group">
                    <span class="cv__resp-area">{r.area}</span>
                    <ul>{r.items.map((it) => <li>{it}</li>)}</ul>
                  </div>
                ))}
              </div>
            ) : (
              <ul class="cv__resp-flat">
                {d.highlights.map((h) => <li>{h}</li>)}
              </ul>
            )}
            <p class="cv__stack">{d.stack.join(" · ")}</p>
          </article>
        );
      })}
    </section>

    <footer class="cv__foot">
      <span>{me.name}</span>
      <a href={canonical.origin + url("/")}>{canonical.host}{url("/")}</a>
    </footer>
  </main>

  <script is:inline>
    // When opened via the "Download CV" button (/resume?download), auto-open the
    // browser's print dialog so the visitor can save this page as a PDF. The
    // proposed filename comes from document.title, which Chrome/Safari use as the
    // default — we swap it to a clean CV name for the duration of the print only.
    (function () {
      if (!new URLSearchParams(location.search).has("download")) return;
      function go() {
        const cvName = document.body.dataset.cvName || "CV";
        const original = document.title;
        document.title = cvName;
        window.addEventListener("afterprint", () => { document.title = original; }, { once: true });
        window.print();
      }
      if (document.readyState === "complete") go();
      else window.addEventListener("load", go);
    })();
  </script>
</body>
</html>

<style is:global>
  * { box-sizing: border-box; }
  html { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  body {
    margin: 0;
    background: #eef1f6;
    color: #1a1d29;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 13.5px;
    line-height: 1.55;
  }
  a { color: #0a66c2; text-decoration: none; }

  .print-bar {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 10;
    padding: 10px 16px;
    border: 0;
    border-radius: 8px;
    background: #0a0e27;
    color: #fff;
    font: 500 13px "IBM Plex Mono", monospace;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(10, 14, 39, 0.25);
  }
  .print-bar:hover { background: #1a2150; }

  .cv {
    max-width: 820px;
    margin: 32px auto;
    padding: 48px 56px;
    background: #fff;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border-radius: 4px;
  }

  .cv__head {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    padding-bottom: 20px;
    border-bottom: 2px solid #0a0e27;
    margin-bottom: 24px;
  }
  .cv__head h1 { margin: 0; font-size: 34px; letter-spacing: -0.5px; }
  .cv__role { margin: 4px 0 12px; color: #2a3050; font-weight: 600; }
  .cv__bio { margin: 0; max-width: 52ch; color: #444a5e; }
  .cv__contact {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: right;
    font-size: 12.5px;
    color: #444a5e;
    white-space: nowrap;
  }
  .cv__contact li { margin-bottom: 4px; }

  .cv__section { margin-bottom: 22px; }
  .cv__section h2 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #6b7280;
    border-bottom: 1px solid #e2e6ee;
    padding-bottom: 6px;
    margin: 0 0 14px;
  }

  /* Personal details */
  .cv__details { margin: 0; display: grid; gap: 6px 28px; grid-template-columns: 1fr 1fr; }
  .cv__details > div { display: flex; gap: 10px; break-inside: avoid; }
  .cv__details dt { margin: 0; min-width: 96px; color: #6b7280; font-weight: 500; }
  .cv__details dd { margin: 0; color: #1a1d29; }

  .cv__desc { margin: 0; color: #444a5e; }
  .cv__summary-line { margin-bottom: 6px; }

  /* Technical-skills taxonomy */
  .cv__skills { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 32px; }
  .cv__skills--tax { margin-top: 12px; }
  .cv__skills .cv__entry { margin-bottom: 0; }
  .cv__skills strong { display: block; font-size: 13px; }
  .cv__skills span { color: #444a5e; font-size: 12.5px; }

  .cv__soft { margin-top: 14px; break-inside: avoid; }
  .cv__soft > strong { display: block; font-size: 13px; margin-bottom: 4px; }
  .cv__soft ul { margin: 0; padding-left: 18px; columns: 2; column-gap: 32px; }
  .cv__soft li { color: #444a5e; margin-bottom: 2px; }

  /* Proficiency table */
  .cv__table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .cv__table th, .cv__table td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #eef1f6; }
  .cv__table th {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px;
    color: #6b7280; font-weight: 600; border-bottom: 1px solid #d8deea;
  }
  .cv__table tr { break-inside: avoid; }
  .cv__table td:nth-child(2) { display: flex; align-items: center; gap: 8px; }
  .cv__bar { display: inline-flex; gap: 3px; }
  .cv__bar span { width: 14px; height: 6px; border-radius: 2px; background: #dde3ee; }
  .cv__bar span.on { background: #0a0e27; }
  .cv__level { color: #6b7280; font: 500 11px "IBM Plex Mono", monospace; }
  .cv__legend { margin: 8px 0 0; font-size: 11px; color: #6b7280; }

  /* Experience */
  .cv__proj { margin-bottom: 16px; break-inside: avoid; }
  .cv__proj-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .cv__proj-head strong { font-size: 15px; }
  .cv__yr { font: 500 12px "IBM Plex Mono", monospace; color: #6b7280; white-space: nowrap; }
  .cv__proj-meta { margin: 1px 0 5px; font-weight: 500; color: #2a3050; font-size: 12.5px; }
  .cv__resp { margin: 6px 0 0; }
  .cv__resp-group { margin-bottom: 5px; }
  .cv__resp-area { font-size: 12px; font-weight: 600; color: #2a3050; }
  .cv__resp ul, .cv__resp-flat { margin: 2px 0 0; padding-left: 18px; }
  .cv__resp li, .cv__resp-flat li { color: #444a5e; margin-bottom: 2px; }
  .cv__resp-flat { margin-top: 6px; }
  .cv__stack { margin: 6px 0 0; font: 400 12px "IBM Plex Mono", monospace; color: #6b7280; }

  .cv__foot {
    display: flex;
    justify-content: space-between;
    margin-top: 28px;
    padding-top: 14px;
    border-top: 1px solid #e2e6ee;
    font-size: 12px;
    color: #6b7280;
  }

  @media print {
    body { background: #fff; font-size: 11.5px; }
    .print-bar { display: none; }
    /* Padding on .cv guarantees a visible inset even if the user picks
       "Margins: None" in the print dialog (which zeroes out @page margins).
       @page margin then adds consistent top/bottom margin on every page. */
    .cv { margin: 0; max-width: none; box-shadow: none; padding: 6mm 10mm; border-radius: 0; }
    .cv__section { margin-bottom: 16px; }
    .cv__section h2 { break-after: avoid; }
    .cv__proj, .cv__entry, .cv__soft, .cv__details > div { break-inside: avoid; }
    .cv__table tr, .cv__resp-group { break-inside: avoid; }
    a { color: #1a1d29; }
    @page { margin: 10mm; }
  }
</style>
