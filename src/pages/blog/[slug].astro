---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { url } from "../../lib/path";
import "../../styles/pages/post.css";

const me = (await getEntry("profile", "me"))!.data;

export async function getStaticPaths() {
    const posts = (await getCollection("blog")).sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
    );
    return posts.map((post, i) => ({
        params: { slug: post.id },
        props: {
            post,
            prev: posts[i - 1] ?? null,
            next: posts[i + 1] ?? null,
            related: posts.filter((_, j) => j !== i).slice(0, 3),
        },
    }));
}

const { post, prev, next, related } = Astro.props;
const { Content } = await render(post);
const a = post.data;

const fmtDate = (d: Date) =>
    d.toLocaleDateString("en-US", { month: "long", year: "numeric" });
const tints = ["0,217,255", "187,134,252", "0,245,255", "255,0,110"];

const xHandle = (me.socials.find((s) => s.name === "X")?.url ?? "")
    .replace(/\/+$/, "")
    .split("/")
    .pop();
---

<Layout title={`${a.title} — ${me.name}`} active="blog" description={a.excerpt} ogType="article">
    <div id="progress"></div>
    <main id="main" data-screen-label="Blog detail">
        <article class="wrap article-head">
            <a class="crumb" href={url("/blog")}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
                All articles
            </a>
            <div class="reveal">
                <span class="tag">{a.cat}</span>
                <h1 class="h-glow">{a.title}</h1>
                <div class="article-meta">
                    <div class="author">
                        <span class="author__ava">
                            <img src={url(me.avatar)} alt={me.name} onerror="this.remove()" />
                            {me.initial}
                        </span>
                        <div><b>{me.name}</b><span>{me.role}</span></div>
                    </div>
                    <span class="meta-dot"></span>
                    <span class="mono">{fmtDate(a.pubDate)}</span>
                    <span class="meta-dot"></span>
                    <span class="mono">{a.read} read</span>
                </div>
            </div>
        </article>

        <div class="wrap">
            <div class="article-banner reveal" style={`background:radial-gradient(80% 120% at 30% 20%,rgba(${a.tint},.18),transparent)`}>
                <div class="scan-line"></div>
                <pre style={`color:rgba(${a.tint},.7)`}>{a.code}</pre>
            </div>
        </div>

        <div class="wrap">
            <div class="prose reveal">
                <Content />
            </div>

            <div class="article-foot">
                <div class="label">Filed under</div>
                <div class="chips"><span class="chip chip--on">{a.cat}</span><span class="chip">Engineering</span><span class="chip">{me.name}</span></div>
                <div class="share">
                    <span class="mono" style="font-family:var(--mono);font-size:13px;color:var(--faint)">Share this transmission</span>
                    <div class="share__btns" id="share" data-title={a.title} data-via={xHandle}>
                        <a href="#" id="shareX" target="_blank" rel="noopener" aria-label="Share on X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.6 8.7L23.3 22h-6.9l-5.4-7-6.2 7H1.7l8.2-9.3L1 2h7.1l4.9 6.4L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/></svg></a>
                        <a href="#" id="shareLinkedIn" target="_blank" rel="noopener" aria-label="Share on LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0zM.25 8.25h4.5V24H.25zM8.25 8.25h4.31v2.15h.06c.6-1.13 2.07-2.32 4.26-2.32 4.56 0 5.4 3 5.4 6.9V24h-4.5v-6.96c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.67 1.8-2.67 3.67V24h-4.5z"/></svg></a>
                        <a href="#" id="copyLink" aria-label="Copy link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg></a>
                    </div>
                </div>
            </div>

            <nav class="pager">
                {prev ? (
                    <a class="prev" href={url(`/blog/${prev.id}`)}><span class="dir">← Previous</span><span class="ttl">{prev.data.title}</span></a>
                ) : (
                    <span class="empty"></span>
                )}
                {next ? (
                    <a class="next" href={url(`/blog/${next.id}`)}><span class="dir">Next →</span><span class="ttl">{next.data.title}</span></a>
                ) : (
                    <span class="empty"></span>
                )}
            </nav>

            <section class="related">
                <h2 class="section-title h-glow" style="font-size:26px">Keep reading</h2>
                <div class="rel-grid">
                    {related.map((r, i) => {
                        const t = tints[i % tints.length];
                        return (
                            <a class="card rel" href={url(`/blog/${r.id}`)}>
                                <div class="rel__viz" style={`background:radial-gradient(70% 90% at 60% 20%,rgba(${t},.16),transparent)`}><code style={`color:rgba(${t},.7)`}>{r.data.code}</code></div>
                                <div class="rel__body"><span class="tag">{r.data.cat}</span><h3>{r.data.title}</h3><div class="post-meta"><span>{fmtDate(r.data.pubDate)}</span><span>·</span><span>{r.data.read}</span></div></div>
                            </a>
                        );
                    })}
                </div>
            </section>
        </div>
    </main>

    <script slot="scripts">
      document.addEventListener("astro:page-load", () => {
        const main = document.getElementById("main");
        if (!main) return;
        if (window.__revealInView) window.__revealInView(main);
        else main.querySelectorAll(".reveal").forEach(el => el.classList.add("in"));

        // reading progress bar
        const bar = document.getElementById("progress");
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
        };
        const ac = new AbortController();
        window.addEventListener("scroll", onScroll, { passive: true, signal: ac.signal });
        document.addEventListener("astro:before-swap", () => ac.abort(), { once: true });
        onScroll();

        // share intents (built client-side so the URL matches the deployed domain)
        const share = document.getElementById("share");
        if (share) {
          const url = encodeURIComponent(location.href);
          const title = encodeURIComponent(share.dataset.title || document.title);
          const via = share.dataset.via;
          const x = document.getElementById("shareX");
          const li = document.getElementById("shareLinkedIn");
          if (x) x.href = `https://x.com/intent/tweet?url=${url}&text=${title}` + (via ? `&via=${via}` : "");
          if (li) li.href = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
        }

        // copy link
        const copy = document.getElementById("copyLink");
        if (copy) copy.addEventListener("click", e => {
          e.preventDefault();
          const done = () => {
            const o = copy.innerHTML;
            copy.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>';
            setTimeout(() => copy.innerHTML = o, 1600);
          };
          if (navigator.clipboard) navigator.clipboard.writeText(location.href).then(done).catch(done); else done();
        });
      });
    </script>
</Layout>
