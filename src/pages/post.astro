---
import Layout from "../layouts/Layout.astro";
import "../styles/pages/post.css";
---

<Layout title="Article — TrisJr" active="blog">
    <div id="progress"></div>
    <main id="main" data-screen-label="Blog detail"></main>

    <script is:inline src="/assets/projects-data.js" slot="data"></script>
    <script is:inline slot="scripts">
      (function () {
        const esc = s => String(s).replace(/[&<>"]/g, c => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;"
        }[c]));

        // naive token highlighter for code blocks
        function hl(code) {
          let s = esc(code);
          s = s.replace(/(\/\/[^\n]*|#[^\n]*)/g, '<span class="cm">$1</span>');
          s = s.replace(/(&quot;[^&]*&quot;)/g, '<span class="str">$1</span>');
          s = s.replace(/\b(fn|let|pub|use|impl|struct|enum|async|await|return|const|var)\b/g, '<span class="kw">$1</span>');
          return s;
        }

        function renderBody(blocks) {
          return blocks.map(b => {
            if (b.t === "p") return `<p>${esc(b.c)}</p>`;
            if (b.t === "h") return `<h2>${esc(b.c)}</h2>`;
            if (b.t === "quote") return `<blockquote>${esc(b.c)}</blockquote>`;
            if (b.t === "code") return `<pre class="code"><span class="lang">${esc(b.lang || "code")}</span><code>${hl(b.c)}</code></pre>`;
            return "";
          }).join("");
        }

        const params = new URLSearchParams(location.search);
        const id = params.get("id");
        const idx = ARTICLES.findIndex(a => a.id === id);
        const main = document.getElementById("main");

        if (idx === -1) {
          document.getElementById("progress").style.display = "none";
          main.innerHTML = `<div class="wrap notfound">
        <p class="kicker" style="justify-content:center">// 404</p>
        <h1 class="h-glow">Signal lost</h1>
        <p>That article drifted out of range. Let's get you back to the transmission log.</p>
        <a class="btn btn--primary" href="/blog">Back to blog</a>
      </div>`;
          return;
        }

        const a = ARTICLES[idx];
        const prev = ARTICLES[idx - 1];
        const next = ARTICLES[idx + 1];
        const related = ARTICLES.filter((x, i) => i !== idx).slice(0, 3);
        const tints = ["0,217,255", "187,134,252", "0,245,255", "255,0,110"];
        document.title = a.title + " — TrisJr";

        main.innerHTML = `
      <article class="wrap article-head">
        <a class="crumb" href="/blog">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
          All articles
        </a>
        <div class="reveal">
          <span class="tag">${esc(a.cat)}</span>
          <h1 class="h-glow">${esc(a.title)}</h1>
          <div class="article-meta">
            <div class="author">
              <span class="author__ava">T</span>
              <div><b>TrisJr</b><span>Full-Stack Developer</span></div>
            </div>
            <span class="meta-dot"></span>
            <span class="mono">${esc(a.date)}</span>
            <span class="meta-dot"></span>
            <span class="mono">${esc(a.read)} read</span>
          </div>
        </div>
      </article>

      <div class="wrap">
        <div class="article-banner reveal" style="background:radial-gradient(80% 120% at 30% 20%,rgba(${a.tint},.18),transparent)">
          <div class="scan-line"></div>
          <pre style="color:rgba(${a.tint},.7)">${esc(a.code)}</pre>
        </div>
      </div>

      <div class="wrap">
        <div class="prose reveal">${renderBody(a.body)}</div>

        <div class="article-foot">
          <div class="label">Filed under</div>
          <div class="chips"><span class="chip chip--on">${esc(a.cat)}</span><span class="chip">Engineering</span><span class="chip">TrisJr</span></div>
          <div class="share">
            <span class="mono" style="font-family:var(--mono);font-size:13px;color:var(--faint)">Share this transmission</span>
            <div class="share__btns">
              <a href="#" aria-label="Share on X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.6 8.7L23.3 22h-6.9l-5.4-7-6.2 7H1.7l8.2-9.3L1 2h7.1l4.9 6.4L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/></svg></a>
              <a href="#" aria-label="Share on LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0zM.25 8.25h4.5V24H.25zM8.25 8.25h4.31v2.15h.06c.6-1.13 2.07-2.32 4.26-2.32 4.56 0 5.4 3 5.4 6.9V24h-4.5v-6.96c0-1.66-.03-3.8-2.32-3.8-2.32 0-2.67 1.8-2.67 3.67V24h-4.5z"/></svg></a>
              <a href="#" id="copyLink" aria-label="Copy link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg></a>
            </div>
          </div>
        </div>

        <nav class="pager">
          ${prev ? `<a class="prev" href="/post?id=${prev.id}"><span class="dir">← Previous</span><span class="ttl">${esc(prev.title)}</span></a>` : `<span class="empty"></span>`}
          ${next ? `<a class="next" href="/post?id=${next.id}"><span class="dir">Next →</span><span class="ttl">${esc(next.title)}</span></a>` : `<span class="empty"></span>`}
        </nav>

        <section class="related">
          <h2 class="section-title h-glow" style="font-size:26px">Keep reading</h2>
          <div class="rel-grid">
            ${related.map((r, i) => {
          const t = tints[i % tints.length];
          return `<a class="card rel" href="/post?id=${r.id}">
                <div class="rel__viz" style="background:radial-gradient(70% 90% at 60% 20%,rgba(${t},.16),transparent)"><code style="color:rgba(${t},.7)">${esc(r.code)}</code></div>
                <div class="rel__body"><span class="tag">${esc(r.cat)}</span><h3>${esc(r.title)}</h3><div class="post-meta"><span>${esc(r.date)}</span><span>·</span><span>${esc(r.read)}</span></div></div>
              </a>`;
        }).join("")}
          </div>
        </section>
      </div>`;

        // reveal injected content
        if (window.__revealInView) window.__revealInView(main); else main.querySelectorAll(".reveal").forEach(el => el.classList.add("in"));

        // reading progress bar
        const bar = document.getElementById("progress");
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
        };
        window.addEventListener("scroll", onScroll, {passive: true});
        onScroll();

        // copy link
        const copy = document.getElementById("copyLink");
        if (copy) copy.addEventListener("click", e => {
          e.preventDefault();
          const done = () => {
            const o = copy.innerHTML;
            copy.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>';
            setTimeout(() => copy.innerHTML = o, 1600);
          };
          if (navigator.clipboard) navigator.clipboard.writeText(location.href).then(done).catch(done); else done();
        });

        window.scrollTo(0, 0);
      })();
    </script>
</Layout>
